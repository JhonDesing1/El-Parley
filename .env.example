# ════════════════════════════════════════════════
#   APUESTAVALUE — .env.example
#   Copia este archivo como .env.local y rellena.
# ════════════════════════════════════════════════

# ─── Next.js / Site ───────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=ApuestaValue

# ─── Supabase ─────────────────────────────────────
# https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # ⚠️ SOLO server-side
SUPABASE_PROJECT_ID=xxxxxxxxxxxxxxxx
SUPABASE_DB_PASSWORD=...

# ─── API-Football (RapidAPI) ──────────────────────
# https://www.api-football.com/ — plan gratuito 100 req/día
API_FOOTBALL_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
API_FOOTBALL_HOST=v3.football.api-sports.io

# ─── The Odds API (fallback/complemento) ──────────
# https://the-odds-api.com/ — 500 req/mes gratis
ODDS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── NewsAPI ──────────────────────────────────────
# https://newsapi.org/
NEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe (pagos globales) ──────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...

# ─── PayU (Colombia) ──────────────────────────────
PAYU_MERCHANT_ID=...
PAYU_ACCOUNT_ID=...
PAYU_API_KEY=...
PAYU_API_LOGIN=...
PAYU_ENV=sandbox   # sandbox | production

# ─── OneSignal (push notifications) ───────────────
NEXT_PUBLIC_ONESIGNAL_APP_ID=...
ONESIGNAL_REST_API_KEY=...

# ─── Cron secret (proteger endpoints de Vercel Cron) ─
CRON_SECRET=$(openssl rand -hex 32)

# ─── Afiliados (tags por casa) ────────────────────
NEXT_PUBLIC_BETPLAY_AFF=apuestavalue01
NEXT_PUBLIC_WPLAY_AFF=apuestavalue02
NEXT_PUBLIC_CODERE_AFF=apuestavalue03
NEXT_PUBLIC_RIVALO_AFF=apuestavalue04
NEXT_PUBLIC_1XBET_AFF=apuestavalue05

# ─── Analytics ────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
